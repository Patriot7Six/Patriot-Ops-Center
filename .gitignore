# ── Devcontainer ──────────────────────────────────────────────
# .devcontainer/ IS committed — it configures GitHub Codespaces.
# Codespaces secrets (env vars) are set in:
#   github.com → Settings → Codespaces → Secrets
# Never put real secrets in .devcontainer/devcontainer.json

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ── Next.js ───────────────────────────────────────────────────
.next/
out/
build/

# ── Environment variables — NEVER commit these ────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# Use Doppler to manage all secrets — see sprint7/README.md
# .env.example is committed intentionally (no real values)

# ── Vercel ────────────────────────────────────────────────────
.vercel

# ── Sentry ────────────────────────────────────────────────────
.sentryclirc

# ── Storybook ─────────────────────────────────────────────────
storybook-static/

# ── Testing ───────────────────────────────────────────────────
coverage/
.nyc_output/

# ── TypeScript ────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── OS files ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ── Editor / IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Trigger.dev ───────────────────────────────────────────────
.trigger/

# ── Misc ──────────────────────────────────────────────────────
.cache/
.parcel-cache/
dist/
tmp/
temp/
.documents
.docs

package-lock.json

# ============================================================
# Patriot Ops Center — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
#
# Environments:
#   Beta (current):     https://beta.patriot-ops.com
#   Production (later): https://patriot-ops.com
#
# Note: patriot-ops.com currently hosts the interest-gathering
# landing page. The full app runs at beta.patriot-ops.com.
# When going to production, update NEXT_PUBLIC_APP_URL and
# all Supabase/Stripe redirect URLs to patriot-ops.com.
# ============================================================

# ── App URL ──────────────────────────────────────────────────
# Beta:
NEXT_PUBLIC_APP_URL=https://beta.patriot-ops.com
# Production (swap this when launching to patriot-ops.com):
# NEXT_PUBLIC_APP_URL=https://patriot-ops.com

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Keep this secret — only used server-side in webhook handlers
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Anthropic ────────────────────────────────────────────────
# Found in: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stripe ───────────────────────────────────────────────────
# IMPORTANT: Use TEST keys during beta. Swap for live keys at production launch.
#
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
#
# Found in: Stripe Dashboard → Developers → Webhooks → [your endpoint] → Signing secret
# For local dev: use the whsec_ printed by `stripe listen --forward-to localhost:3000/api/stripe/webhook`
STRIPE_WEBHOOK_SECRET=whsec_...
#
# Found in: Stripe Dashboard → Product Catalog → [Ranger product] → Price ID
STRIPE_PRICE_PRO_MONTHLY=price_...
#
# Found in: Stripe Dashboard → Product Catalog → [Special Ops product] → Price ID
STRIPE_PRICE_ELITE_MONTHLY=price_...

# ── Resend ───────────────────────────────────────────────────
# Verified sending domain: email.patriot-ops.com
# FROM address will be: no-reply@email.patriot-ops.com
#
# Setup: Resend Dashboard → Domains → Add domain → email.patriot-ops.com
# Add the DNS records Resend provides to your DNS provider.
# Once verified, create an API key → paste below.
RESEND_API_KEY=re_...

# ── Local Dev Notes ──────────────────────────────────────────
# For local Stripe webhooks:
#   1. Install: brew install stripe/stripe-cli/stripe
#   2. Run:     stripe listen --forward-to localhost:3000/api/stripe/webhook
#   3. Copy the printed whsec_... into STRIPE_WEBHOOK_SECRET above
#   4. The local whsec_ is DIFFERENT from the dashboard webhook signing secret.
#      Switch back to the dashboard whsec_ when deploying to Vercel.
